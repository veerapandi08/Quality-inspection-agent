# Copy this file to ".env" in the same folder and fill in your real values.

# ---- Server ----
PORT=3000
JWT_SECRET=change-this-to-a-long-random-secret

# ---- Email (Gmail SMTP) ----
# 1. Turn on 2-Step Verification on your Google account.
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an App Password for "Mail" and paste the 16-character code below (no spaces).
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your16charapppassword
# Email shown as sender name
SMTP_FROM_NAME=Quality Inspection Agent

# If you don't set SMTP_USER/SMTP_PASS, the app automatically falls back to
# "demo mode": emails are logged to the server console instead of actually sent,
# and verification codes / alerts still work for testing.
